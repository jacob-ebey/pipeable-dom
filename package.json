{
	"name": "pipeable-dom",
	"version": "0.0.4",
	"type": "module",
	"description": "An HTML parser allowing for HTML to be streamed into a live DOM.",
	"license": "MIT",
	"author": "Jacob Ebey",
	"files": ["dist"],
	"types": "dist/pipeable-dom.d.ts",
	"main": "dist/pipeable-dom.js",
	"exports": {
		".": {
			"types": "./dist/pipeable-dom.d.ts",
			"import": "./dist/pipeable-dom.js",
			"default": "./dist/pipeable-dom.js"
		},
		"./package.json": "./package.json"
	},
	"keywords": ["dom", "html", "parser", "streaming", "transform"],
	"scripts": {
		"build": "tsup",
		"fix": "biome check --fix .",
		"lint": "biome check .",
		"test": "vitest"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.3",
		"@types/serve-handler": "6.1.4",
		"@vitest/browser": "2.1.2",
		"playwright": "1.47.2",
		"serve-handler": "6.1.5",
		"tsup": "8.3.0",
		"typescript": "5.6.2",
		"vite": "5.4.8",
		"vitest": "2.1.2"
	}
}
