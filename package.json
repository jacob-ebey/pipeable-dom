{
  "name": "pipeable-dom",
  "version": "0.0.2",
  "type": "module",
  "description": "An HTML parser allowing for HTML to be streamed into a live DOM.",
  "license": "MIT",
  "author": "Jacob Ebey",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/pipeable-dom.d.ts",
      "import": "./dist/pipeable-dom.js",
      "default": "./dist/pipeable-dom.js"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "dom",
    "html",
    "parser",
    "streaming",
    "transform"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "devDependencies": {
    "@vitest/browser": "2.1.2",
    "playwright": "1.47.2",
    "serve-handler": "6.1.5",
    "tsup": "8.3.0",
    "typescript": "5.6.2",
    "vite": "5.4.8",
    "vitest": "2.1.2"
  }
}
